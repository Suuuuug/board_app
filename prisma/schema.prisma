generator client {
  provider      = "prisma-client-js"
  output        = "../app/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(uuid())
  name        String       @unique
  pin         String
  todos       Todo[]
  completions Completion[]
}

model Todo {
  id          String  @id @default(uuid())
  userId      String
  text        String
  completed   Boolean @default(false)
  completedAt String?
  createdAt   String
  user        User    @relation(fields: [userId], references: [id])
}

model Completion {
  id          String @id @default(uuid())
  userId      String
  userName    String
  todoId      String
  task        String
  completedAt String
  user        User   @relation(fields: [userId], references: [id])
}
